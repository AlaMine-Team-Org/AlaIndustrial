.gradle/
build/
out/
versions/
run/
runs/
# but DO track manual test-session history (alamod-test writes here; alamod-sync commits it)
!docs/testing/runs/
# 3D block render working dirs (per-face source textures + 1024px block render);
# only the flattened tools/*_3d.png at tools root are tracked (used by preview HTML)
tools/*_3d/
.idea/
.vscode/
# ZCode agent local state (plans, session data) — not source, do not publish.
.zcode/
*.iml
*.log
*.tmp
*.bak
Thumbs.db
.DS_Store
.fabric/
remappedSrc/
bin/

# Python bytecode (docs/tools validators)
__pycache__/
*.pyc

# Generated standalone distribution files (rebuild via: python tools/build_standalone.py)
tools/AlaIndustrial_Guide.html

# Generated guide website (rebuild via: python docs/tools/gen_guide_site.py --all)
# Like build/, site/ is an output artifact, not source — regenerated from docs/blocks/.
site/

# Sound generation tool (tools/tts/) — secrets + generated audio stay local.
# The .env holds the ElevenLabs API key; output/ holds generated candidate sounds.
# Triple-protected from the public repo: this gitignore, sync-code.sh allowlist
# (tools/ is not in SYNC_PATHS), and scan-clean.sh L4 denylist ((^|/)tools/).
.env
.env.local
.env.production
# .env.example is the documented placeholder — keep it tracked.
!.env.example
tools/tts/output/
