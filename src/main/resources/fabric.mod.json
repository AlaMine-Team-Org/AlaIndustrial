{
	"schemaVersion": 1,
	"id": "alaindustrial",
	"version": "${version}",
	"name": "AlaIndustrial",
	"description": "An EU-powered technology mod for Minecraft, built incrementally from specs.",
	"authors": [
		"AlaMine Team"
	],
	"contact": {
		"homepage": "https://alamine.day/",
		"sources": "https://github.com/AlaMine-Team-Org"
	},
	"license": "MIT",
	"icon": {
		"16": "assets/alaindustrial/icon-16.png",
		"32": "assets/alaindustrial/icon-32.png",
		"64": "assets/alaindustrial/icon-64.png",
		"128": "assets/alaindustrial/icon-128.png",
		"256": "assets/alaindustrial/icon-256.png",
		"512": "assets/alaindustrial/icon-512.png"
	},
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.alaindustrial.Industrialization"
		],
		"client": [
			"dev.alaindustrial.IndustrializationClient"
		],
		"rei_client": [
			"dev.alaindustrial.compat.rei.AlaReiPlugin"
		]
	},
	"mixins": [
		"alaindustrial.mixins.json",
		{
			"config": "alaindustrial.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=25",
		"fabric-api": "*",
		"team_reborn_energy": "*"
	}
}
